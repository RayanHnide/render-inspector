{
  "name": "@rayan_hn/render-inspector",
  "version": "0.2.0",
  "description": "Detect React rerenders fast: why components rerender, render count tracking, render timing, and expensive computation debugging.",
  "author": "Rayan Hnedi",
  "license": "MIT",
  "funding": "https://github.com/RayanHnide",
  "engines": {
    "node": ">=18.18.0"
  },
  "type": "module",
  "homepage": "https://github.com/RayanHnide/render-inspector#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RayanHnide/render-inspector.git"
  },
  "bugs": {
    "url": "https://github.com/RayanHnide/render-inspector/issues"
  },
  "keywords": [
    "react",
    "performance",
    "render",
    "profiler",
    "debug",
    "nextjs",
    "hooks",
    "why-did-you-render",
    "react-performance",
    "react-debugging",
    "rerender",
    "render-tracking",
    "frontend-performance",
    "developer-tools",
    "vite",
    "app-router",
    "react-profiler",
    "react-rerender",
    "rerender-debugging",
    "nextjs-performance",
    "why-did-you-render-react",
    "react-optimization",
    "react-devtools",
    "web-vitals",
    "ui-performance"
  ],
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "clean": "node -e \"fs.rmSync('dist', { recursive: true, force: true })\"",
    "build": "npm run clean && npm run build:js && npm run build:types",
    "build:js": "esbuild src/index.ts --bundle --external:react --format=esm --banner:js='\"use client\";' --sourcemap --outfile=dist/index.js && esbuild src/index.ts --bundle --external:react --format=cjs --banner:js='\"use client\";' --sourcemap --outfile=dist/index.cjs",
    "build:types": "tsc --project tsconfig.build.json",
    "test": "tsx tests/run-tests.tsx",
    "typecheck": "tsc --noEmit",
    "pack:check": "npm pack --dry-run",
    "release:ci": "semantic-release",
    "release:ci:dry": "semantic-release --dry-run",
    "release": "npm publish --access public",
    "release:dry": "npm publish --access public --dry-run",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build"
  },
  "peerDependencies": {
    "react": ">=18.0.0"
  },
  "devDependencies": {
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/npm": "^13.1.5",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@testing-library/react": "^15.0.7",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^22.7.4",
    "@types/react": "^19.2.14",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "esbuild": "^0.28.0",
    "jsdom": "^24.1.3",
    "react": "^19.2.6",
    "react-dom": "^18.2.0",
    "semantic-release": "^25.0.3",
    "tsx": "^4.19.2",
    "typescript": "^5.5.4"
  }
}
